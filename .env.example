# ─── LLM : OpenAI ─────────────────────────────────────────────
# Clé API OpenAI : https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Identifiant du modèle utilisé par le deep agent
AGENT_MODEL=openai:gpt-4o-mini

# ─── LangSmith (tracing / debug) ─────────────────────────────
# Clé API : https://smith.langchain.com  (Settings > API Keys)
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=data-analysis-agent
