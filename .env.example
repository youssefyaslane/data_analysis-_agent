# ─── LLM : Google Gemini ─────────────────────────────────────
# Clé API Gemini : https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# Identifiant du modèle utilisé par le deep agent
AGENT_MODEL=google_genai:gemini-3.5-flash

# ─── LangSmith (tracing / debug) ─────────────────────────────
# Clé API : https://smith.langchain.com  (Settings > API Keys)
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=data-analysis-agent
